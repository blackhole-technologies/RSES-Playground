{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "core/**/*.ts",
    "engines/**/*.ts",
    "modules/**/*.ts",
    "shared/**/*.ts",
    "bin/**/*.ts",
    "vendor/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "vendor/*/tests/**",
    "ui/**/*"
  ]
}
