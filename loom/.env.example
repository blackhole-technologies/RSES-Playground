# Deploy-time environment for loom. Copy to .env and fill real values.
# Never commit .env.

NODE_ENV=development
PORT=3000

# PostgreSQL connection. Required even for Phase 0 (config validates on boot).
# Phase 0 does not actually connect; the pool is created but unused.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/loom
DATABASE_POOL_SIZE=10

# 64-char random string. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-random-string-at-least-32-chars-long

# Canonical public URL (used in meta tags and outgoing RSS feeds)
PUBLIC_URL=http://localhost:3000

# Behind a reverse proxy?
TRUST_PROXY=false

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Background queue (Phase 1+)
QUEUE_CONCURRENCY=4

# Feed polling (Phase 4+)
FEED_POLL_CONCURRENCY=4
FEED_POLL_DEFAULT_INTERVAL=900
FEED_POLL_TIMEOUT=10000

# Integration tests point here. Matches the loom_test database created by
# docker-compose's init-test-db.sql script. Not read by the server itself —
# only by tests that gate on `process.env.TEST_DATABASE_URL`.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/loom_test
